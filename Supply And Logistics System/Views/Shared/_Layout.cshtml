<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Lucas Supply System</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom shadow-sm">
            <div class="container-fluid">

                <!-- BRAND -->
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    <span class="text-primary">📦</span> Supply System
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">

                    <!-- LEFT MENU -->
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Product" asp-action="Index">Products</a>
                        </li>

                        @if (Context.Session.GetString("Role") == "Customer")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Cart" asp-action="Index">Cart</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Order" asp-action="MyOrders">My Orders</a>
                            </li>
                        }

                        @if (Context.Session.GetString("Role") == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-warning" asp-controller="Admin" asp-action="Index">Admin Panel</a>
                            </li>
                        }

                        @if (Context.Session.GetString("Role") == "WarehouseStaff")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-info" asp-controller="WarehouseStaff" asp-action="Index">Warehouse Panel</a>
                            </li>
                        }

                        @if (Context.Session.GetString("Role") == "Courier")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-success" asp-controller="Courier" asp-action="Index">Courier Panel</a>
                            </li>
                        }
                    </ul>

                    <!-- RIGHT MENU (Auth) -->
                    <ul class="navbar-nav gap-2">
                        @if (Context.Session.GetInt32("UserId") != null)
                        {
                            <li class="nav-item">
                                <a class="btn btn-outline-danger btn-sm px-3" asp-controller="Account" asp-action="Logout">
                                    Logout
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-outline-light btn-sm px-3" asp-controller="Account" asp-action="Login">
                                    Login
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary btn-sm px-3" asp-controller="Account" asp-action="Register">
                                    Register
                                </a>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <!-- MAIN CONTENT -->
    <div class="container mt-4">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <!-- FOOTER ATUALIZADO -->
    <footer class="border-top footer text-muted mt-auto py-4 bg-light">
        <div class="container">
            <div class="row align-items-center">
                <!-- Direitos e Privacy -->
                <div class="col-md-4 text-center text-md-start mb-3 mb-md-0">
                    <span class="fw-bold text-dark">Lucas Supply System</span> &copy; 2026
                    <br />
                    <a asp-controller="Home" asp-action="Privacy" class="text-decoration-none small">Privacy Policy</a>
                </div>

                <!-- Contacto Telefónico -->
                <div class="col-md-4 text-center mb-3 mb-md-0">
                    <div class="d-flex justify-content-center align-items-center gap-2">
                        <i class="bi bi-telephone-fill text-primary"></i>
                        <span>+90 500 000 00 00</span>
                    </div>
                </div>

                <!-- Redes Sociais -->
                <div class="col-md-4 text-center text-md-end">
                    <a href="https://instagram.com" class="text-dark me-3 fs-5" target="_blank"><i class="bi bi-instagram"></i></a>
                    <a href="https://facebook.com" class="text-dark fs-5" target="_blank"><i class="bi bi-facebook"></i></a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>