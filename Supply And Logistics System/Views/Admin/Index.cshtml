@using Supply_And_Logistics_System.Models.Products
@model List<Product>

@{
    ViewData["Title"] = "Admin Panel";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Admin Panel - Product Management</h2>

    <div class="d-flex gap-2">
        <a asp-controller="Admin"
           asp-action="CreateProduct"
           class="btn btn-success">
            + Create New Product
        </a>

        <a asp-controller="Admin"
           asp-action="Orders"
           class="btn btn-primary">
            View Orders
        </a>

        <a asp-controller="Admin"
           asp-action="Workers"
           class="btn btn-info text-white">
            👥 Manage Users
        </a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No products found.
    </div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Type</th>
                <th>Price</th>
                <th>Stock</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td>
                        <strong>@p.Name</strong><br />
                        <small class="text-muted">@p.GetDescription()</small>
                    </td>

                    <td>
                        @(p is CompositeProduct ? "Composite" : "Simple")
                    </td>

                    <td>@p.GetPrice().ToString("0.00") €</td>

                    <td>@p.GetStock()</td>

                    <td class="d-flex gap-2">
                        <a asp-controller="Admin"
                           asp-action="EditProduct"
                           asp-route-id="@p.Id"
                           class="btn btn-primary btn-sm">
                            Edit
                        </a>

                        <form asp-controller="Admin"
                              asp-action="DeleteProduct"
                              method="post">

                            <input type="hidden" name="id" value="@p.Id" />

                            <button class="btn btn-danger btn-sm">
                                Delete
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}