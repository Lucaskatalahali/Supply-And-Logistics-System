@{
    ViewData["Title"] = "Home";
}

<!-- HERO SECTION -->
<div class="px-4 py-5 text-center">
    <div class="py-4">

        <div class="mb-4">
            <i class="bi bi-truck" style="font-size: 4rem; color: #0d6efd;"></i>
        </div>

        <h1 class="display-5 fw-bold">
            Welcome to <span class="text-primary">Lucas Supply System</span>
        </h1>

        <p class="col-lg-6 mx-auto lead text-muted mt-3">
            Your smart supply and logistics platform.
            Browse our products and place your order in seconds.
        </p>

        <div class="d-flex gap-3 justify-content-center mt-4">

            @if (Context.Session.GetInt32("UserId") != null &&
                        Context.Session.GetString("Role") == "Customer")
            {
                <a asp-controller="Product" asp-action="Index"
                   class="btn btn-primary btn-lg px-5">
                    <i class="bi bi-box-seam me-2"></i> Browse Products
                </a>

                <a asp-controller="Cart" asp-action="Index"
                   class="btn btn-outline-primary btn-lg px-5">
                    <i class="bi bi-cart me-2"></i> My Cart
                </a>
            }
            else if (Context.Session.GetInt32("UserId") == null)
            {
                <a asp-controller="Account" asp-action="Login"
                   class="btn btn-primary btn-lg px-5">
                    <i class="bi bi-box-arrow-in-right me-2"></i> Login
                </a>

                <a asp-controller="Account" asp-action="Register"
                   class="btn btn-outline-primary btn-lg px-5">
                    <i class="bi bi-person-plus me-2"></i> Register
                </a>
            }
            else
            {
                <!-- Admin, WarehouseStaff, Courier vêem só produtos -->
                <a asp-controller="Product" asp-action="Index"
                   class="btn btn-primary btn-lg px-5">
                    <i class="bi bi-box-seam me-2"></i> View Products
                </a>
            }

        </div>
    </div>
</div>

<hr />

<!-- FEATURES SECTION -->
<div class="container py-4">
    <div class="row g-4 text-center">

        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 p-4">
                <div class="text-primary mb-3">
                    <i class="bi bi-shield-check" style="font-size: 2.5rem;"></i>
                </div>
                <h5 class="fw-bold">Secure Payments</h5>
                <p class="text-muted small">
                    Pay with credit card or bank transfer.
                    Your transactions are safe with us.
                </p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 p-4">
                <div class="text-primary mb-3">
                    <i class="bi bi-truck" style="font-size: 2.5rem;"></i>
                </div>
                <h5 class="fw-bold">Fast Delivery</h5>
                <p class="text-muted small">
                    Choose from Aras, Yurtici or Global Express.
                    Track your order in real time.
                </p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 p-4">
                <div class="text-primary mb-3">
                    <i class="bi bi-box2-heart" style="font-size: 2.5rem;"></i>
                </div>
                <h5 class="fw-bold">Wide Selection</h5>
                <p class="text-muted small">
                    From simple products to full composite packs.
                    Everything you need in one place.
                </p>
            </div>
        </div>

    </div>
</div>